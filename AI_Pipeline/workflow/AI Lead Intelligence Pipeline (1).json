      "parameters": {
        "jsCode": "return items.map(item => {\n  let data = item.json.output;\n\n  // remove ```json if present\n  if (typeof data === \"string\") {\n    data = data.replace(/```json|```/g, \"\").trim();\n    data = JSON.parse(data);\n  }\n\n  return { json: data };\n});"
      },
      "type": "n8n-nodes-base.code",
