      "name": "structuring"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "You are a data extraction and lead intelligence AI.\n\nYour task is to analyze company/lead input data and return a structured JSON object.\n\nSTRICT OUTPUT RULES:\n- Return ONLY valid JSON\n- Do NOT wrap output inside any field like \"output\"\n- Do NOT use markdown (no ``` or ```json)\n- Do NOT include explanations or extra text\n- Do NOT include duplicate JSON blocks\n- Output must be a single JSON object only\n\n---\n\nOUTPUT SCHEMA (MUST FOLLOW EXACTLY):\n\n{\n  \"company_name\": string,\n  \"industry\": string,\n  \"short_description\": string,\n  \"products_or_services\": [string],\n  \"target_customers\": [string],\n  \"value_proposition\": string,\n  \"tone\": string,\n  \"keywords\": [string]\n}\n\n---\n\nRULES:\n- Keep values concise and relevant\n- products_or_services must be an array of strings\n- target_customers must be an array of strings\n- keywords must be 3–8 relevant terms\n- If information is missing, infer logically from context (do NOT leave empty unless impossible)\n\n---\n\nIMPORTANT:\nReturn ONLY the JSON object. Nothing else.",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        2320,
        -16
      ],
      "id": "454d116e-b83d-4076-a36a-059c9aa1532b",
      "name": "HTML extracting",
      "alwaysOutputData": false,
      "notesInFlow": false,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "You are a lead scoring engine.\n\nAnalyze the input and return ONLY ONE valid JSON object.\n\nIMPORTANT RULES:\n- Return ONLY ONE result per input lead\n- Do NOT generate multiple examples\n- Do NOT include explanations\n- Do NOT output multiple JSON objects\n- Output must be valid JSON (parsable)\n\nOutput format:\n{\n  \"lead_score\": number (0-100),\n  \"confidence_score\": number (0-1),\n  \"segment\": \"Hot | Warm | Cold\",\n  \"reasoning\": \"\",\n  \"buying_intent_signals\": [],\n  \"risk_factors\": [],\n  \"recommended_action\": \"\"\n}\n\nInput:\n{{$json}}\n",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        2976,
        -16
      ],
      "id": "93803f8c-d700-481d-aba4-5037802864c7",
      "name": "score generating"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let raw = item.json.output;\n\n  if (!raw) return { json: {} };\n\n  // remove markdown code blocks\n  if (typeof raw === \"string\") {\n    raw = raw\n      .replace(/```json/g, \"\")\n      .replace(/```/g, \"\")\n      .trim();\n  }\n\n  let parsed;\n\n  try {\n    parsed = typeof raw === \"string\" ? JSON.parse(raw) : raw;\n  } catch (e) {\n    return {\n      json: {\n        error: \"Invalid JSON\",\n        raw_output: raw\n      }\n    };\n  }\n\n  const clean = {};\n\n  // basic fields\n  if (parsed.lead_score != null) clean.lead_score = parsed.lead_score;\n  if (parsed.confidence_score != null) clean.confidence_score = parsed.confidence_score;\n  if (parsed.segment) clean.segment = parsed.segment;\n  if (parsed.reasoning) clean.reasoning = parsed.reasoning;\n  if (parsed.recommended_action) clean.recommended_action = parsed.recommended_action;\n\n  // arrays (ONLY if not empty)\n  if (Array.isArray(parsed.buying_intent_signals) && parsed.buying_intent_signals.length > 0) {\n    clean.buying_intent_signals = parsed.buying_intent_signals;\n  }\n\n  if (Array.isArray(parsed.risk_factors) && parsed.risk_factors.length > 0) {\n    clean.risk_factors = parsed.risk_factors;\n  }\n\n  return { json: clean };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3360,
        -16
      ],
      "id": "6cdca0eb-662b-457b-aca9-8637d1e600c6",
      "name": "structyring 1"
    },
    {
      "parameters": {
        "jsCode": "const leads = items.map(i => i.json);\n\nconst total = leads.length;\n\nconst avgScore =\n  leads.reduce((sum, l) => sum + l.lead_score, 0) / total;\n\nconst hot = leads.filter(l => l.segment === \"Hot\").length;\nconst warm = leads.filter(l => l.segment === \"Warm\").length;\nconst cold = leads.filter(l => l.segment === \"Cold\").length;\n\nconst topLeads = leads\n  .sort((a, b) => b.lead_score - a.lead_score)\n  .slice(0, 3);\n\nreturn [\n  {\n    json: {\n      summary: {\n        total_leads: total,\n        average_lead_score: avgScore,\n        hot_leads: hot,\n        warm_leads: warm,\n        cold_leads: cold\n      },\n      top_leads: topLeads,\n      executive_insight:\n        `Out of ${total} leads, ${hot} are hot, with an average score of ${avgScore.toFixed(1)}. Focus immediate outreach on high-scoring leads.`\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3584,
        -16
      ],
      "id": "e0604604-c392-4352-b5da-89597bcef3ac",
      "name": "structuring lead"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const data = item.json;\n\n  const summary = data.summary || {};\n  const leads = data.top_leads || [];\n\n  const leadRows = leads.map((lead, i) => {\n    return `\n      <tr>\n        <td><b>${i + 1}</b></td>\n        <td>${lead.lead_score ?? \"-\"}</td>\n        <td>${lead.segment ?? \"-\"}</td>\n        <td>${lead.reasoning ?? \"-\"}</td>\n        <td>${lead.recommended_action ?? \"-\"}</td>\n      </tr>\n    `;\n  }).join(\"\");\n\n  const html = `\n  <html>\n    <body style=\"font-family: Arial; background:#f6f6f6; padding:20px;\">\n      \n      <div style=\"max-width:800px; margin:auto; background:#fff; padding:20px; border-radius:10px;\">\n        \n        <h2 style=\"color:#2c3e50;\">📊 Executive Lead Report</h2>\n\n        <h3>📌 Summary</h3>\n        <ul>\n          <li><b>Total Leads:</b> ${summary.total_leads ?? 0}</li>\n          <li><b>Average Score:</b> ${summary.average_lead_score?.toFixed(1) ?? 0}</li>\n          <li><b>🔥 Hot Leads:</b> ${summary.hot_leads ?? 0}</li>\n          <li><b>🟠 Warm Leads:</b> ${summary.warm_leads ?? 0}</li>\n          <li><b>🔵 Cold Leads:</b> ${summary.cold_leads ?? 0}</li>\n        </ul>\n\n        <h3>🏆 Top Leads</h3>\n\n        <table border=\"1\" cellpadding=\"8\" cellspacing=\"0\" style=\"border-collapse: collapse; width:100%;\">\n          <tr style=\"background:#2c3e50; color:white;\">\n            <th>#</th>\n            <th>Score</th>\n            <th>Segment</th>\n            <th>Reasoning</th>\n            <th>Action</th>\n          </tr>\n          ${leadRows}\n        </table>\n\n        <h3>🧠 Executive Insight</h3>\n        <p>${data.executive_insight ?? \"\"}</p>\n\n        <br/>\n        <p style=\"color:gray; font-size:12px;\">\n          Generated by AI Lead Intelligence System\n        </p>\n\n      </div>\n\n    </body>\n  </html>\n  `;\n\n  return {\n    json: {\n      subject: `📊 Lead Report - ${summary.total_leads ?? 0} Leads | Avg Score ${summary.average_lead_score?.toFixed(1) ?? 0}`,\n      html: html\n    }\n  };\n});"
      },
